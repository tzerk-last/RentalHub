@model IEnumerable<RentalHub.Models.Wishlist>

@{
    ViewData["Title"] = "Mis favoritos";
}

<div class="container py-4">
    <h2 class="mb-4">Mis favoritos</h2>

    @if (!Model.Any())
    {
        <p class="text-muted">No tienes inmuebles guardados todavia.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Explorar inmuebles</a>
    }
    else
    {
        <div class="row g-3">
            @foreach (var w in Model)
            {
                var p = w.Property;
                var img = p.Images.FirstOrDefault();
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        @if (img != null)
                        {
                            <img src="@img.ImageUrl" class="card-img-top"
                                 style="height:200px;object-fit:cover" />
                        }
                        <div class="card-body">
                            <h5 class="card-title">@p.Title</h5>
                            <p class="text-muted mb-1">@p.City</p>
                            <p class="fw-bold text-success">@p.PricePerNight.ToString("C") / noche</p>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <a asp-controller="Home" asp-action="Detail" asp-route-id="@p.Id"
                               class="btn btn-outline-primary btn-sm flex-fill">
                                Ver detalles
                            </a>
                            <a asp-controller="Wishlist" asp-action="Toggle" asp-route-propertyId="@p.Id"
                               class="btn btn-outline-danger btn-sm">
                                Quitar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
