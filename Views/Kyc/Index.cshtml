@model RentalHub.Models.KycVerification

@{
    ViewData["Title"] = "Verificacion de identidad";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="mb-4">Verificacion de identidad</h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (Model == null)
            {
                <div class="alert alert-warning">
                    No has verificado tu identidad todavia.
                    Para reservar inmuebles necesitas completar este paso.
                </div>
                <a asp-action="Upload" class="btn btn-primary">Verificar ahora</a>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center p-4">

                        @if (Model.Status == "Approved")
                        {
                            <div class="text-success mb-3" style="font-size:48px">&#10003;</div>
                            <h4 class="text-success">Identidad verificada</h4>
                            <p class="text-muted">Tu cuenta esta habilitada para realizar reservas.</p>
                        }
                        else if (Model.Status == "Pending")
                        {
                            <div class="text-warning mb-3" style="font-size:48px">&#9679;</div>
                            <h4 class="text-warning">En revision</h4>
                            <p class="text-muted">Tus documentos estan siendo revisados. Te notificaremos por correo.</p>
                            <p class="text-muted small">Enviado: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        }
                        else
                        {
                            <div class="text-danger mb-3" style="font-size:48px">&#10007;</div>
                            <h4 class="text-danger">Verificacion rechazada</h4>
                            <p class="text-muted">Tus documentos no pudieron ser verificados. Intenta de nuevo.</p>
                            <a asp-action="Upload" class="btn btn-danger mt-2">Reintentar</a>
                        }

                    </div>
                </div>
            }

        </div>
    </div>
</div>
