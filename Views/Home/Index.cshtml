@model IEnumerable<RentalHub.Models.Property>

@{
    ViewData["Title"] = "Inmuebles disponibles";
}

<div class="container py-4">

    <h2 class="mb-4">Encuentra tu proximo hospedaje</h2>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="text" name="ciudad" value="@ViewBag.Ciudad"
                   class="form-control" placeholder="Ciudad (ej: Medellin)" />
        </div>
        <div class="col-md-3">
            <input type="date" name="entrada" value="@ViewBag.Entrada" class="form-control" />
        </div>
        <div class="col-md-3">
            <input type="date" name="salida" value="@ViewBag.Salida" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Buscar</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No hay inmuebles disponibles con esos filtros.
        </div>
    }

    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    @{
                        var img = p.Images.FirstOrDefault();
                    }
                    @if (img != null)
                    {
                        <img src="@img.ImageUrl" class="card-img-top"
                             style="height:200px;object-fit:cover" alt="@p.Title" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center"
                             style="height:200px;color:#aaa;font-size:13px;">
                            Sin imagen
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@p.Title</h5>
                        <p class="text-muted mb-1">@p.City</p>
                        <p class="mb-1">@p.Bedrooms hab - @p.Bathrooms banos - @p.MaxGuests huespedes</p>
                        <p class="fw-bold text-success">
                            @p.PricePerNight.ToString("C") / noche
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Home" asp-action="Detail" asp-route-id="@p.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            Ver detalles
                        </a>
                        <a asp-controller="Wishlist" asp-action="Toggle" asp-route-propertyId="@p.Id"
                           class="btn btn-outline-secondary btn-sm">
                            Favorito
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
