@model RentalHub.Models.Property

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row">

        <!-- Imágenes -->
        <div class="col-md-7">
            @if (Model.Images.Any())
            {
                <div id="carousel" class="carousel slide mb-3" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Model.Images.ElementAt(i).ImageUrl"
                                     class="d-block w-100 rounded"
                                     style="height:360px;object-fit:cover" />
                            </div>
                        }
                    </div>
                    @if (Model.Images.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3"
                     style="height:360px;color:#aaa;">Sin imágenes</div>
            }

            <h2>@Model.Title</h2>
            <p class="text-muted">@Model.City — @Model.Address</p>
            <p>@Model.Description</p>

            <div class="d-flex gap-4 mb-3">
                <span>🛏 @Model.Bedrooms habitaciones</span>
                <span>🚿 @Model.Bathrooms baños</span>
                <span>👥 Hasta @Model.MaxGuests huéspedes</span>
            </div>
        </div>

        <!-- Panel de reserva -->
        <div class="col-md-5">
            <div class="card shadow-sm p-4 sticky-top" style="top:80px">
                <h4 class="mb-1">@Model.PricePerNight.ToString("C") <small class="text-muted fs-6">/ noche</small></h4>

                <form asp-controller="Reservation" asp-action="Create" method="post" class="mt-3">
                    <input type="hidden" name="PropertyId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Fecha de entrada</label>
                        <input type="date" name="CheckIn" class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Fecha de salida</label>
                        <input type="date" name="CheckOut" class="form-control"
                               min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" required />
                    </div>

                    <div class="alert alert-info py-2 small">
                        Check-in: 2:00 PM · Check-out: 12:00 PM
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Reservar
                    </button>
                </form>

                <hr />
                <a asp-controller="Wishlist" asp-action="Toggle" asp-route-propertyId="@Model.Id"
                   class="btn btn-outline-secondary w-100">
                    ♡ Guardar en favoritos
                </a>
            </div>
        </div>

    </div>
</div>
