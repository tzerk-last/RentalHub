@model IEnumerable<RentalHub.Models.Property>

@{
    ViewData["Title"] = "Mis inmuebles";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mis inmuebles</h2>
        <a asp-action="Create" class="btn btn-primary">+ Nuevo inmueble</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No tienes inmuebles registrados todavia.
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Titulo</th>
                    <th>Ciudad</th>
                    <th>Precio / noche</th>
                    <th>Disponible</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.City</td>
                        <td>@item.PricePerNight.ToString("C")</td>
                        <td>
                            <span class="badge @(item.IsAvailable ? "bg-success" : "bg-secondary")">
                                @(item.IsAvailable ? "Si" : "No")
                            </span>
                        </td>
                        <td class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>
